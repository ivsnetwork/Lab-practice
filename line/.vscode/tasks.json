{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build line",
      "type": "shell",
      "command": "g++",
      "args": [
        "line.cpp"
      ],
      "osx": {
        "args": [
          "line.cpp",
          "-g",
          "-O0",
          "-Wall",
          "./lib/mac/libsprite.a",
          "-I./include",
          "-I/usr/X11/include",
          "-L/usr/X11R6/lib",
          "-lX11",
          "-std=c++20"
        ]
      },
      "linux": {
        "args": [
          "line.cpp",
          "-g",
          "-O0",
          "-Wall",
          "./lib/linux/libsprite.a",
          "-I./include",
          "-I/usr/include/X11",
          "-L/usr/X11R6/lib",
          "-lX11",
          "-std=c++20"
        ]
      },
      "group": "build",
      "problemMatcher": "$gcc"
    }
  ]
}